# サーバー設定
PORT=3000
NODE_ENV=development

# Gemini API設定（Hermes Agent用）
# 無料APIキーを https://aistudio.google.com/apikey から取得してください
# ※ Gemini Proサブスクリプションとは別の無料枠です（個人利用には十分な1000+回/日）
GEMINI_API_KEY=your-gemini-api-key-here
# デフォルトはFlash（無料枠が大きく高速）。高品質が必要ならgemini-2.5-proに変更
GEMINI_MODEL=gemini-2.5-flash

# 思源ノート設定
SIYUAN_API_URL=http://localhost:6806
SIYUAN_API_TOKEN=your-siyuan-api-token-here
SIYUAN_NOTEBOOK_ID=

# API認証トークン（iOS Shortcuts / Chrome拡張機能用）
API_AUTH_TOKEN=your-secret-auth-token-here
